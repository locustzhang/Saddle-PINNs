    label = "Saddle-Adam"

    def __init__(self, out_dim, pde_type):
        super().__init__(out_dim, pde_type)
        self.lam_ic = float(LAMBDA_INIT)
        self.lam_inv = float(LAMBDA_INIT)

        self.m_inv = 0.0
        self.v_inv = 0.0
        self.t_inv = 0
        self._was_warmup = True

    def _dual_adam_step(self, lam, c_signal, m, v, t, lam_max, lam_min):
        t += 1
        m = DUAL_BETA1 * m + (1 - DUAL_BETA1) * c_signal
        v = DUAL_BETA2 * v + (1 - DUAL_BETA2) * (c_signal ** 2)

        m_hat = m / (1 - DUAL_BETA1 ** t)
        v_hat = v / (1 - DUAL_BETA2 ** t)

        step = DUAL_LR_ADAM * m_hat / (np.sqrt(v_hat) + DUAL_EPS)
        lam = float(np.clip(lam + step, lam_min, lam_max))

        return lam, m, v, t

    def reset_inv(self):
        self.m_inv = 0.0
        self.v_inv = 0.0
        self.t_inv = 0

    def compute_loss(self, x_f, t_f, x_ic, ts,
                     residual_fn, ic_fn, inv_fn, inv0,
                     warmup, tau):

        Lp, _ = causal_pde_loss(self, x_f, t_f, residual_fn, tau)
        Lic = ic_loss(self, x_ic, ic_fn, self.out_dim)

        zero = torch.tensor(0.0, device=DEVICE)

        if warmup:
            Ltot = Lp + IC_WEIGHT_VANILLA * Lic
            return Ltot, dict(Lp=Lp, Lic=Lic, Cinv=zero, Linv=zero, Ltot=Ltot)

        if self.pde_type == "conservative":
            c_stack = constraint_conservative(self, ts, inv_fn, inv0)
        else:
            c_stack = constraint_burgers(self, ts, inv0)

        linv = torch.mean(self.lam_inv * c_stack + 0.5 * MU_PENALTY * c_stack ** 2)
        Ltot = Lp + self.lam_ic * Lic + 0.5 * MU_PENALTY * Lic ** 2 + linv

        return Ltot, dict(
            Lp=Lp, Lic=Lic,
            Cinv=c_stack.mean().detach(),
            Linv=linv.detach(),
            Ltot=Ltot
        )

    def post_step(self, scalars):
        warmup = scalars["warmup"]

        if self._was_warmup and not warmup:
            self.reset_inv()
            self._was_warmup = False
            self.lam_inv = LAMBDA_INIT

        if not warmup:
            c_signal = float(scalars["Cinv"])
            self.lam_inv, self.m_inv, self.v_inv, self.t_inv = self._dual_adam_step(
                self.lam_inv, c_signal,
                self.m_inv, self.v_inv, self.t_inv,
                LAMBDA_MAX, LAMBDA_MIN
            )

# ==============================================================================
# TRAINING LOOP (SA dual ascent supported)
# ==============================================================================
def train_model(model, residual_fn, ic_fn, inv_fn, inv0, tau, desc=""):
    if isinstance(model, SAPINN_Pos):
        net_opt = torch.optim.Adam(model.net.parameters(), lr=LEARNING_RATE)
        dual_opt = torch.optim.Adam([model.log_lam_ic, model.log_lam_inv], lr=SA_LR)
        scheduler = None

    elif isinstance(model, SAPINN_Equality):
        net_opt = torch.optim.Adam(model.net.parameters(), lr=LEARNING_RATE)
        dual_opt = torch.optim.Adam([model.lam_ic, model.lam_inv], lr=SA_LR)
        scheduler = None

    else:
        opt = torch.optim.Adam(model.parameters(), lr=LEARNING_RATE)
        scheduler = torch.optim.lr_scheduler.MultiStepLR(opt, LR_MILESTONES, LR_GAMMA)

    ts = time_slices(N_TS_INVARIANT)
    x_ic = sample_ic(N_IC_TRAIN)
    x_f, t_f = sample_colloc(N_TRAIN_COLLOC)

    rec = LossRecord()
    pbar = tqdm(range(1, ITERATIONS + 1), desc=desc, ncols=120, leave=False)

    for it in pbar:
        warmup = (it <= WARMUP_ITERS)

        if (RESAMPLE_INTERVAL > 0 and not warmup
                and (it - WARMUP_ITERS) % RESAMPLE_INTERVAL == 0):
            x_f, t_f = resample_collocation(model, x_f, t_f, residual_fn)

        model.train()

        # SA-PINN-pos
        if isinstance(model, SAPINN_Pos):
            loss_net, comps = model.compute_loss(
                x_f, t_f, x_ic, ts,
                residual_fn, ic_fn, inv_fn, inv0,
                warmup, tau
            )

            net_opt.zero_grad()
            loss_net.backward()
            nn.utils.clip_grad_norm_(model.net.parameters(), 1.0)
            net_opt.step()

            if not warmup:
                lic_val = comps["Lic"].detach()
                c_inv = comps["Cinv"].detach()
                lam_ic = model.log_lam_ic.exp()
                lam_inv = model.log_lam_inv.exp()

                dual_loss = -(lam_ic * lic_val + lam_inv * torch.abs(c_inv))
                dual_opt.zero_grad()
                dual_loss.backward()
                dual_opt.step()
            else:
                dual_opt.zero_grad()

        # SA-PINN-eq
        elif isinstance(model, SAPINN_Equality):
            loss_net, comps = model.compute_loss(
                x_f, t_f, x_ic, ts,
                residual_fn, ic_fn, inv_fn, inv0,
                warmup, tau
            )

            net_opt.zero_grad()
            loss_net.backward()
            nn.utils.clip_grad_norm_(model.net.parameters(), 1.0)
            net_opt.step()

            if not warmup:
                lic_val = comps["Lic"].detach()
                c_inv = comps["Cinv"].detach()

                dual_loss = -(model.lam_ic * lic_val + model.lam_inv * c_inv)

                dual_opt.zero_grad()
                dual_loss.backward()
                dual_opt.step()

                with torch.no_grad():
                    model.lam_inv.clamp_(LAMBDA_MIN, LAMBDA_MAX)
                    model.lam_ic.clamp_(-LAMBDA_IC_MAX, LAMBDA_IC_MAX)
            else:
                dual_opt.zero_grad()

        # standard methods
        else:
            opt.zero_grad()
            loss, comps = model.compute_loss(
                x_f, t_f, x_ic, ts,
                residual_fn, ic_fn, inv_fn, inv0,
                warmup, tau
            )
            loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            opt.step()
            scheduler.step()

        scalars = {k: float(v.item()) if torch.is_tensor(v) else float(v)
                   for k, v in comps.items()}
        scalars["warmup"] = warmup

        model.post_step(scalars)

        rec.Lp.append(scalars["Lp"])
        rec.Lic.append(scalars["Lic"])
        rec.Cinv.append(scalars["Cinv"])
        rec.Linv.append(scalars["Linv"])
        rec.Ltot.append(scalars["Ltot"])

        if isinstance(model, SAPINN_Pos):
            rec.lam_ic.append(float(model.lam_ic))
            rec.lam_inv.append(float(model.lam_inv))
        elif isinstance(model, SAPINN_Equality):
            rec.lam_ic.append(float(model.lam_ic.detach().cpu().item()))
            rec.lam_inv.append(float(model.lam_inv.detach().cpu().item()))
        else:
            rec.lam_ic.append(float(getattr(model, "lam_ic", 0.0)))
            rec.lam_inv.append(float(getattr(model, "lam_inv", 0.0)))

        if it % LOG_INTERVAL == 0:
            pbar.set_postfix(
                Lp=f"{scalars['Lp']:.1e}",
                Lic=f"{scalars['Lic']:.1e}",
                c=f"{scalars['Cinv']:.1e}",
                lam=f"{rec.lam_inv[-1]:.2f}",
                W="Y" if warmup else "N"
            )

    return rec

# ==============================================================================
# OUT-OF-SAMPLE RESIDUAL TEST (Correctness Evidence)
# ==============================================================================
def eval_residual_oos(model, residual_fn, n=N_RESID_TEST):
    model.eval()
    with torch.enable_grad():
        x = torch.rand(n, 1, device=DEVICE) * (X_MAX - X_MIN) + X_MIN
        t = torch.rand(n, 1, device=DEVICE) * T_FINAL
        xt = torch.cat([x, t], dim=1).requires_grad_(True)
        r = residual_fn(model(xt), xt)
        r2 = (r ** 2).mean(dim=1)
        return {
            "mean": float(r2.mean().item()),
            "max": float(r2.max().item()),
            "p95": float(torch.quantile(r2, 0.95).item()),
        }

# ==============================================================================
# EVALUATION: CONSTRAINT ERROR + CONSERVATION CURVE
# ==============================================================================
def eval_constraint_error(model, pde_type, inv_fn, inv0):
    model.eval()
    eps = 1e-12
    norm = abs(inv0) + eps
    errs = []

    with torch.enable_grad():
        for t in T_EVAL_LIST:
            x = quad_grid(N_INV_QUAD)

            if pde_type == "conservative":
                xt = torch.cat([x, float(t) * torch.ones_like(x)], dim=1)
                u = model(xt)
                I = inv_fn(u, x).item()
                c = abs((I - inv0) / norm)
            else:
                t_leaf = torch.tensor(float(t), device=DEVICE, requires_grad=True)
                xt = torch.cat([x, t_leaf.expand_as(x)], dim=1)
                u = model(xt)
                E = PDE.burgers_E(u, x)
                D = PDE.burgers_D(u, x)
                dEdt = autograd.grad(E, t_leaf, create_graph=False)[0].item()
                c = abs((dEdt + D.item()) / norm)

            errs.append(c)

    return {"mean": float(np.mean(errs)), "max": float(np.max(errs))}

def conservation_curve(model, pde_type, inv_fn, inv0):
    model.eval()
    eps = 1e-12
    norm = abs(inv0) + eps

    t_arr = np.linspace(0.0, T_FINAL, N_CONSERVATION_PTS)
    vals = []

    for t in t_arr:
        with torch.enable_grad():
            x = quad_grid(N_INV_QUAD)

            if pde_type == "conservative":
                xt = torch.cat([x, float(t) * torch.ones_like(x)], dim=1)
                u = model(xt)
                I = inv_fn(u, x).item()
                c = (I - inv0) / norm
            else:
                t_leaf = torch.tensor(float(t), device=DEVICE, requires_grad=True)
                xt = torch.cat([x, t_leaf.expand_as(x)], dim=1)
                u = model(xt)
                E = PDE.burgers_E(u, x)
                D = PDE.burgers_D(u, x)
                dEdt = autograd.grad(E, t_leaf, create_graph=False)[0].item()
                c = (dEdt + D.item()) / norm

            vals.append(float(c))

    drift = float(np.polyfit(t_arr, vals, 1)[0])

    return {
        "t": t_arr.tolist(),
        "c": vals,
        "mean_abs": float(np.mean(np.abs(vals))),
        "max_abs": float(np.max(np.abs(vals))),
        "drift_rate": drift
    }

# ==============================================================================
# REFERENCE SOLVER: Spectral ETDRK4 (Kassam-Trefethen style)
# ==============================================================================
def spectral_grid(nx=NX_REF):
    x = np.linspace(X_MIN, X_MAX, nx, endpoint=False)
    L = X_MAX - X_MIN
    k = (2.0 * np.pi / L) * np.fft.fftfreq(nx, d=L/nx)
    return x, k

def etdrk4_coeffs(Lk, dt):
    """
    Kassam & Trefethen ETDRK4 coefficients for u_t = Lu + N(u).
    Lk: array of linear operator eigenvalues in Fourier space.
    """
    E = np.exp(dt * Lk)
    E2 = np.exp(dt * Lk / 2.0)

    M = 16
    r = np.exp(1j * np.pi * (np.arange(1, M+1) - 0.5) / M)
    LR = dt * Lk[:, None] + r[None, :]

    Q = dt * np.real(np.mean((np.exp(LR/2.0) - 1.0) / LR, axis=1))
    f1 = dt * np.real(np.mean((-4 - LR + np.exp(LR)*(4 - 3*LR + LR**2)) / (LR**3), axis=1))
    f2 = dt * np.real(np.mean((2 + LR + np.exp(LR)*(-2 + LR)) / (LR**3), axis=1))
    f3 = dt * np.real(np.mean((-4 - 3*LR - LR**2 + np.exp(LR)*(4 - LR)) / (LR**3), axis=1))

    return E, E2, Q, f1, f2, f3

def solve_reference(pde_name: str, out_dim: int):
    """
    Returns reference solution snapshots:
        x_ref: (nx,)
        t_ref: (nt_save,)
        u_ref: (nt_save, nx, out_dim)
    """
    x, k = spectral_grid(NX_REF)
    dt = DT_REF_KS if pde_name == "KS" else DT_REF_DEFAULT
    nsteps = int(round(T_FINAL / dt))
    if nsteps < 10:
        raise RuntimeError("Too few reference steps. Decrease dt or increase T_FINAL.")

    # save indices
    save_idx = np.arange(0, nsteps + 1, SAVE_EVERY)
    t_save = save_idx * dt
    if t_save[-1] < T_FINAL - 1e-12:
        save_idx = np.append(save_idx, nsteps)
        t_save = np.append(t_save, nsteps * dt)

    # initial condition
    x_torch = torch.tensor(x, dtype=torch.float64)
    if pde_name == "KdV":
        u0 = (0.5 / torch.cosh(x_torch / 2.0) ** 2).numpy()
        u = u0.astype(np.complex128)
        out_dim = 1
    elif pde_name == "Burgers":
        u0 = (-torch.sin(np.pi * x_torch / 10.0)).numpy()
        u = u0.astype(np.complex128)
        out_dim = 1
    elif pde_name == "NLS":
        u0 = torch.exp(-x_torch ** 2 / 2.0).numpy()
        u = u0.astype(np.complex128)  # real initial
        out_dim = 2
    elif pde_name == "KS":
        u0 = torch.cos(np.pi * x_torch / 16.0).numpy()
        u = u0.astype(np.complex128)
        out_dim = 1
    else:
        raise ValueError(pde_name)

    # linear operator in Fourier space
    ik = 1j * k
    k2 = k**2
    k3 = k**3
    k4 = k**4

    if pde_name == "KdV":
        # u_t + 6 u u_x + u_xxx = 0 -> u_t = -u_xxx - 6 u u_x
        Lk = -(1j * k**3)
        def N(u_phys):
            ux = np.fft.ifft(ik * np.fft.fft(u_phys)).real
            return -6.0 * u_phys * ux

    elif pde_name == "Burgers":
        # u_t + u u_x - nu u_xx = 0 -> u_t = nu u_xx - u u_x
        nu = PDE.NU
        Lk = -nu * (k**2)
        def N(u_phys):
            ux = np.fft.ifft(ik * np.fft.fft(u_phys)).real
            return -(u_phys * ux)

    elif pde_name == "NLS":
        # i u_t + 0.5 u_xx + |u|^2 u = 0
        # u_t = i(0.5 u_xx + |u|^2 u)
        Lk = 1j * (-0.5 * k2)
        def N(u_phys):
            return 1j * (np.abs(u_phys)**2) * u_phys

    elif pde_name == "KS":
        # u_t + u u_x + u_xx + u_xxxx = 0 -> u_t = -u_xx - u_xxxx - u u_x
        Lk = (k2 - k4)  # because -u_xx - u_xxxx -> +(k^2 - k^4) in Fourier
        def N(u_phys):
            ux = np.fft.ifft(ik * np.fft.fft(u_phys)).real
            return -(u_phys * ux)

    else:
        raise ValueError(pde_name)

    E, E2, Q, f1, f2, f3 = etdrk4_coeffs(Lk.astype(np.complex128), dt)

    # allocate save arrays
    u_save = np.zeros((len(t_save), NX_REF, out_dim), dtype=np.float64)
    save_ptr = 0

    def save_state(u_complex):
        nonlocal save_ptr
        if pde_name == "NLS":
            u_save[save_ptr, :, 0] = u_complex.real
            u_save[save_ptr, :, 1] = u_complex.imag
        else:
            u_save[save_ptr, :, 0] = u_complex.real
        save_ptr += 1

    save_state(u)

    v = np.fft.fft(u)
    for n in range(1, nsteps + 1):
        u_phys = np.fft.ifft(v).real if pde_name != "NLS" else np.fft.ifft(v)
        Nv = np.fft.fft(N(u_phys))

        a = E2 * v + Q * Nv
        ua = np.fft.ifft(a).real if pde_name != "NLS" else np.fft.ifft(a)
        Na = np.fft.fft(N(ua))

        b = E2 * v + Q * Na
        ub = np.fft.ifft(b).real if pde_name != "NLS" else np.fft.ifft(b)
        Nb = np.fft.fft(N(ub))

        c = E2 * a + Q * (2*Nb - Nv)
        uc = np.fft.ifft(c).real if pde_name != "NLS" else np.fft.ifft(c)
        Nc = np.fft.fft(N(uc))

        v = E * v + f1 * Nv + f2 * (Na + Nb) + f3 * Nc

        if n in save_idx:
            u = np.fft.ifft(v)
            save_state(u)

    return {
        "x": x.astype(np.float64),
        "t": t_save.astype(np.float64),
        "u": u_save,
        "dt": float(dt),
        "nx": int(NX_REF),
        "save_every": int(SAVE_EVERY),
    }

# ==============================================================================
# PINN vs Reference Error Curves
# ==============================================================================
def interp_ref_solution(ref, t_query: float):
    """
    linear interpolation in time for reference snapshots
    ref["u"]: (nt, nx, out_dim)
    """
    t_arr = ref["t"]
    u_arr = ref["u"]

    if t_query <= t_arr[0]:
        return u_arr[0]
    if t_query >= t_arr[-1]:
        return u_arr[-1]

    j = np.searchsorted(t_arr, t_query) - 1
    j = max(0, min(j, len(t_arr) - 2))
    t0, t1 = t_arr[j], t_arr[j+1]
    w = (t_query - t0) / (t1 - t0 + 1e-16)
    return (1-w) * u_arr[j] + w * u_arr[j+1]

def pinn_predict_on_grid(model, x_np: np.ndarray, t_val: float, out_dim: int):
    model.eval()
    with torch.no_grad():
        x = torch.tensor(x_np, device=DEVICE, dtype=torch.float32).reshape(-1, 1)
        t = torch.full_like(x, float(t_val))
        xt = torch.cat([x, t], dim=1)
        u = model(xt).detach().cpu().numpy()
    if out_dim == 1:
        return u[:, 0]
    return u  # (nx, 2)

def compute_ref_error_curves(model, ref, out_dim: int):
    x_ref = ref["x"]
    t_list = np.array(T_EVAL_LIST, dtype=np.float64)

    L2_list = []
    Linf_list = []

    for t in t_list:
        u_ref = interp_ref_solution(ref, float(t))  # (nx, out_dim)
        if out_dim == 1:
            u_ref = u_ref[:, 0]
            u_pred = pinn_predict_on_grid(model, x_ref, float(t), 1)
            err = u_pred - u_ref
            L2 = np.sqrt(np.mean(err**2))
            Linf = np.max(np.abs(err))
        else:
            u_pred = pinn_predict_on_grid(model, x_ref, float(t), 2)
            err = u_pred - u_ref
            L2 = np.sqrt(np.mean(np.sum(err**2, axis=1)))
            Linf = np.max(np.sqrt(np.sum(err**2, axis=1)))

        L2_list.append(float(L2))
        Linf_list.append(float(Linf))

    return {
        "t": t_list.tolist(),
        "L2": L2_list,
        "Linf": Linf_list,
        "L2_mean": float(np.mean(L2_list)),
        "L2_max": float(np.max(L2_list)),
        "Linf_mean": float(np.mean(Linf_list)),
        "Linf_max": float(np.max(Linf_list)),
    }

def build_snapshots(model, ref, out_dim: int):
    x_ref = ref["x"]
    snaps = {"x": x_ref.tolist(), "t": SNAPSHOT_TIMES, "u_pred": [], "u_ref": []}

    for t in SNAPSHOT_TIMES:
        u_ref = interp_ref_solution(ref, float(t))
        if out_dim == 1:
            u_ref = u_ref[:, 0]
            u_pred = pinn_predict_on_grid(model, x_ref, float(t), 1)
            snaps["u_ref"].append(u_ref.tolist())
            snaps["u_pred"].append(u_pred.tolist())
        else:
            u_pred = pinn_predict_on_grid(model, x_ref, float(t), 2)
            snaps["u_ref"].append(u_ref.tolist())
            snaps["u_pred"].append(u_pred.tolist())

    return snaps

