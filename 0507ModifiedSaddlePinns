            "dt": ref["dt"],
            "nt_save": int(len(ref["t"])),
            "wall_time_s": round(ref_time, 4),
            "npz_file": os.path.basename(ref_path),
        },
        "models": {}
    }

    for key, model in variants:
        model.to(DEVICE)

        t0 = time.perf_counter()
        rec = train_model(model, residual_fn, ic_fn, inv_fn, inv0, tau,
                          desc=f"{pde_name}/{model.label}")
        wall = time.perf_counter() - t0

        # correctness evidence
        err_constraint = eval_constraint_error(model, pde_type, inv_fn, inv0)
        curve = conservation_curve(model, pde_type, inv_fn, inv0)
        err_resid = eval_residual_oos(model, residual_fn, n=N_RESID_TEST)
        err_ref = compute_ref_error_curves(model, ref, out_dim)

        snapshots = build_snapshots(model, ref, out_dim)

        # save loss history JSON
        loss_dict = {k: v for k, v in dataclasses.asdict(rec).items()}
        loss_path = os.path.join(RESULT_DIR, f"{pde_name}_{key}_loss.json")
        with open(loss_path, "w") as f:
            json.dump(loss_dict, f, indent=2)

        # save snapshots NPZ (large data)
        snap_npz_path = os.path.join(RESULT_DIR, f"{pde_name}_{key}_snapshots.npz")
        np.savez_compressed(
            snap_npz_path,
            x=np.array(snapshots["x"], dtype=np.float64),
            t=np.array(snapshots["t"], dtype=np.float64),
            u_pred=np.array(snapshots["u_pred"], dtype=np.float64),
            u_ref=np.array(snapshots["u_ref"], dtype=np.float64),
        )

        # save correctness metrics JSON
        metrics = {
            "pde": pde_name,
            "model_key": key,
            "label": model.label,
            "wall_time_s": round(wall, 4),
            "constraint_error": err_constraint,
            "invariant_curve": curve,
            "residual_oos": err_resid,
            "ref_error": err_ref,
            "snapshots_npz": os.path.basename(snap_npz_path),
            "final_lambdas": {
                "lam_ic": float(rec.lam_ic[-1]),
                "lam_inv": float(rec.lam_inv[-1]),
            }
        }

        metrics_path = os.path.join(RESULT_DIR, f"{pde_name}_{key}_metrics.json")
        with open(metrics_path, "w") as f:
            json.dump(metrics, f, indent=2)

        log.info(
            "  [%-14s] |c|mean=%.3e |c|max=%.3e drift=%.3e "
            "resid(mean)=%.3e  ref(L2mean)=%.3e  lam=%.3f  time=%.1fs",
            model.label,
            err_constraint["mean"], err_constraint["max"],
            curve["drift_rate"],
            err_resid["mean"],
            err_ref["L2_mean"],
            float(rec.lam_inv[-1]),
            wall
        )

        exp["models"][key] = {
            "label": model.label,
            "wall_time_s": round(wall, 3),
            "loss_json": os.path.basename(loss_path),
            "metrics_json": os.path.basename(metrics_path),
            "snapshots_npz": os.path.basename(snap_npz_path),

            "error_constraint": err_constraint,
            "error_residual_oos": err_resid,
            "error_reference": err_ref,

            "curve": curve,
            "final_loss": {
                "Lp": rec.Lp[-1],
                "Lic": rec.Lic[-1],
                "Cinv": rec.Cinv[-1],
                "Linv": rec.Linv[-1],
                "Ltot": rec.Ltot[-1]
            },
            "final_lambdas": {
                "lam_ic": rec.lam_ic[-1],
                "lam_inv": rec.lam_inv[-1]
            }
        }

    return exp

# ==============================================================================
# OUTPUT TABLES
# ==============================================================================
def build_ablation_table(all_results):
    rows = []
    for res in all_results:
        row = {"pde": res["pde"], "inv0": res["inv0"], "tau": res["tau"]}
        for k in _VARIANT_KEYS:
            m = res["models"][k]
            row[f"{k}_mean_c"] = m["error_constraint"]["mean"]
            row[f"{k}_max_c"] = m["error_constraint"]["max"]
            row[f"{k}_drift"] = m["curve"]["drift_rate"]
            row[f"{k}_resid_oos_mean"] = m["error_residual_oos"]["mean"]
            row[f"{k}_ref_L2_mean"] = m["error_reference"]["L2_mean"]
            row[f"{k}_ref_Linf_mean"] = m["error_reference"]["Linf_mean"]
            row[f"{k}_time"] = m["wall_time_s"]
            row[f"{k}_lam"] = m["final_lambdas"]["lam_inv"]

        base = max(row["saddle_grad_ref_L2_mean"], 1e-16)
        for k in _VARIANT_KEYS:
            row[f"ratio_{k}_L2_vs_saddle_grad"] = row[f"{k}_ref_L2_mean"] / base

        rows.append(row)
    return rows

def build_conservation_table(all_results):
    rows = []
    for res in all_results:
        for k in _VARIANT_KEYS:
            m = res["models"][k]
            cc = m["curve"]
            rows.append({
                "pde": res["pde"],
                "model": k,
                "label": m["label"],
                "t": cc["t"],
                "c": cc["c"],
                "mean_abs": cc["mean_abs"],
                "max_abs": cc["max_abs"],
                "drift_rate": cc["drift_rate"]
            })
    return rows

def build_lambda_history(all_results):
    rows = []
    for res in all_results:
        for k in _VARIANT_KEYS:
            loss_json = res["models"][k]["loss_json"]
            path = os.path.join(RESULT_DIR, loss_json)
            with open(path, "r") as f:
                loss = json.load(f)
            rows.append({
                "pde": res["pde"],
                "model": k,
                "label": res["models"][k]["label"],
                "lam_inv_history": loss["lam_inv"],
                "lam_ic_history": loss["lam_ic"],
            })
    return rows

