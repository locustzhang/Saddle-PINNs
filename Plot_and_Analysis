OUR_LABELS  = [r"Saddle-$\nabla$", r"Saddle-Adam$^\dagger$"]

# ── Wong (2011) 8-color palette ───────────────────────────────────────────────
_W = dict(black="#000000", orange="#E69F00", sky="#56B4E9",
          green="#009E73", yellow="#F0E442", blue="#0072B2",
          vermil="#D55E00", pink="#CC79A7")
