# STATISTICS REPORT
# ─────────────────────────────────────────────────────────────────────────────
def _sep(ch="─", n=78): return ch * n

def report_statistics():
    table  = load("ablation_table.json")
    curves = load("conservation_curves.json")

    print()
    print("=" * 78)
    print("  JCP NUMERICAL RESULTS — PAPER-READY STATISTICS")
    print("=" * 78)

    # ── 1. Full ablation table ────────────────────────────────────────────────
    print()
    print(_sep())
    print("  TABLE 1 — Mean conservation error |c̄| per method and PDE")
    print(_sep())
    col_w = 14
    hdr   = f"  {'PDE':8s}" + "".join(f"{lbl:>{col_w}s}" for lbl in VARIANT_LABELS_PLAIN)
    print(hdr)
    print("  " + "─" * (8 + col_w * len(VARIANT_KEYS)))
    for row in table:
        line = f"  {row['pde']:8s}"
        for k in VARIANT_KEYS:
            line += f"{row[f'{k}_mean']:>{col_w}.3e}"
        print(line)

    # ── 2. Improvement ratios – both Saddle methods against baselines ─────────
    for our_key, our_lbl in zip(OUR_METHODS, OUR_LABELS):
        print()
        print(_sep())
        print(f"  TABLE 2{OUR_METHODS.index(our_key)+1} — Improvement ratio baseline / {our_lbl}")
        print(_sep())
        baselines = [k for k in VARIANT_KEYS if k != our_key]
        b_labels  = [VARIANT_LABELS_PLAIN[VARIANT_KEYS.index(k)] for k in baselines]
        hdr2      = f"  {'PDE':8s}" + "".join(f"{lbl:>14s}" for lbl in b_labels)
        print(hdr2)
        print("  " + "─" * (8 + 14 * len(baselines)))
        for row in table:
            our = max(row[f"{our_key}_mean"], 1e-16)
            line = f"  {row['pde']:8s}"
            for k in baselines:
                ratio = row[f"{k}_mean"] / our
                marker = " ★" if ratio >= 2 else ""
                line += f"{ratio:>12.2f}×{marker:2s}"
            print(line)

    # ── 3. Geometric mean across all PDEs ─────────────────────────────────────
    print()
    print(_sep())
    print("  TABLE 3 — Geometric mean |c̄| across all 4 PDEs")
    print(_sep())
    geo_means = {}
    for k in VARIANT_KEYS:
        vals = [row[f"{k}_mean"] for row in table]
        geo_means[k] = float(np.exp(np.mean(np.log(vals))))
    sorted_methods = sorted(geo_means.items(), key=lambda x: x[1])
    for rank, (k, gm) in enumerate(sorted_methods, 1):
        lbl    = VARIANT_LABELS_PLAIN[VARIANT_KEYS.index(k)]
        marker = " ◀ BEST" if rank == 1 else ""
        print(f"  {rank}. {lbl:15s}  geo-mean |c̄| = {gm:.3e}{marker}")

    # ── 4. Per-PDE best and worst ─────────────────────────────────────────────
    print()
    print(_sep())
    print("  TABLE 4 — Best / worst method per PDE")
    print(_sep())
    print(f"  {'PDE':10s}  {'Best method':18s}  {'|c̄|_best':>12s}  "
          f"{'Worst method':18s}  {'|c̄|_worst':>12s}  {'Factor':>8s}")
    print("  " + "─" * 78)
    for row in table:
        best_k  = min(VARIANT_KEYS, key=lambda k: row[f"{k}_mean"])
        worst_k = max(VARIANT_KEYS, key=lambda k: row[f"{k}_mean"])
        b_val   = row[f"{best_k}_mean"]
        w_val   = row[f"{worst_k}_mean"]
        factor  = w_val / max(b_val, 1e-16)
        print(f"  {row['pde']:10s}  "
              f"{VARIANT_LABELS_PLAIN[VARIANT_KEYS.index(best_k)]:18s}  {b_val:>12.3e}  "
              f"{VARIANT_LABELS_PLAIN[VARIANT_KEYS.index(worst_k)]:18s}  {w_val:>12.3e}  "
              f"{factor:>8.1f}×")

    # ── 5. Drift-rate ranking ─────────────────────────────────────────────────
    print()
    print(_sep())
    print("  TABLE 5 — Conservation drift rate  d|c̃|/dt  (negative = error decaying)")
    print(_sep())
    print(f"  {'PDE':10s}", end="")
    for lbl in VARIANT_LABELS_PLAIN:
        print(f"  {lbl:>12s}", end="")
    print()
    print("  " + "─" * (10 + 14 * len(VARIANT_KEYS)))
    for row in table:
        print(f"  {row['pde']:10s}", end="")
        for k in VARIANT_KEYS:
            d = row[f"{k}_drift"]
            print(f"  {d:>+12.3e}", end="")
        print()

    # ── 6. Max conservation error summary ────────────────────────────────────
    print()
    print(_sep())
    print("  TABLE 6 — Max conservation error max|c̃(t)| across evaluation horizon")
    print(_sep())
    print(f"  {'PDE':8s}" + "".join(f"{lbl:>{col_w}s}" for lbl in VARIANT_LABELS_PLAIN))
    print("  " + "─" * (8 + col_w * len(VARIANT_KEYS)))
    for row in table:
        line = f"  {row['pde']:8s}"
        for k in VARIANT_KEYS:
            line += f"{row[f'{k}_max']:>{col_w}.3e}"
        print(line)

    # ── 7. Rank-based summary ─────────────────────────────────────────────────
    print()
    print(_sep())
    print("  TABLE 7 — Average rank across 4 PDEs (1=best, lower=better)")
    print(_sep())
    rank_sums = {k: 0 for k in VARIANT_KEYS}
    for row in table:
        vals   = [(k, row[f"{k}_mean"]) for k in VARIANT_KEYS]
        sorted_v = sorted(vals, key=lambda x: x[1])
        for rank, (k, _) in enumerate(sorted_v, 1):
            rank_sums[k] += rank
    avg_ranks = {k: rank_sums[k] / len(table) for k in VARIANT_KEYS}
    for k, avg_r in sorted(avg_ranks.items(), key=lambda x: x[1]):
        lbl    = VARIANT_LABELS_PLAIN[VARIANT_KEYS.index(k)]
        marker = " ◀ BEST" if avg_r == min(avg_ranks.values()) else ""
        print(f"  {lbl:20s}  avg rank = {avg_r:.2f}{marker}")

