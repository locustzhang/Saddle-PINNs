# ── IO helpers ────────────────────────────────────────────────────────────────
def load(fname):
    with open(os.path.join(RESULT_DIR, fname)) as f:
        return json.load(f)

def smooth(arr, w=80):
    return uniform_filter1d(np.array(arr, dtype=float), size=w, mode="nearest")

def savefig(fig, name):
    fig.savefig(os.path.join(FIG_DIR, f"{name}.pdf"))
    fig.savefig(os.path.join(FIG_DIR, f"{name}.png"))
    plt.close(fig)
    print(f"  [fig] {name}.pdf / .png")

def add_label(ax, txt, x=-0.18, y=1.04):
    ax.text(x, y, txt, transform=ax.transAxes,
            fontsize=9, fontweight="bold", va="top", ha="left")

# ─────────────────────────────────────────────────────────────────────────────
# FIGURE 1  Conservation error curves
# ─────────────────────────────────────────────────────────────────────────────
def fig_conservation():
    curves = load("conservation_curves.json")
    fig, axes = plt.subplots(2, 2, figsize=(W2, 4.8))
    axes = axes.flatten()

    for idx, (pde, title) in enumerate(zip(PDE_LIST, PDE_TITLES)):
        ax = axes[idx]
        for key, lbl in zip(VARIANT_KEYS, VARIANT_LABELS):
            item = next((d for d in curves if d["pde"]==pde and d["model"]==key), None)
            if not item: continue
            t = np.array(item["t"])
            c = np.abs(np.array(item["c"]))
            ax.semilogy(t, c, color=COLORS[key], ls=LSTYLES[key], lw=LWIDTHS[key],
                        label=lbl, zorder=4 if key in OUR_METHODS else 2)

        ax.set_title(title, pad=3)
        ax.set_xlabel(r"Time $t$")
        ax.set_ylabel(r"$|\tilde{c}(t)|$")
        ax.set_xlim(0, 1)
        ax.yaxis.set_major_formatter(ticker.LogFormatterSciNotation(labelOnlyBase=False))
        ax.tick_params(which="both", direction="in", length=2.5)
        add_label(ax, f"({'abcd'[idx]})")

    handles, labels = axes[0].get_legend_handles_labels()
    fig.legend(handles, labels, loc="lower center", ncol=len(VARIANT_KEYS),
               bbox_to_anchor=(0.5, -0.04), frameon=True,
               columnspacing=1.0, handlelength=2.5, handletextpad=0.4)
    fig.suptitle(r"Normalised conservation error $|\tilde{c}(t)|\;=\;|I(t)-I_0|\,/\,(1+|I_0|)$",
                 y=1.01, fontsize=9)
    fig.tight_layout(rect=[0, 0.06, 1, 1])
    savefig(fig, "fig1_conservation_curves")


# ─────────────────────────────────────────────────────────────────────────────
# FIGURE 2  Ablation heatmap
# ─────────────────────────────────────────────────────────────────────────────
def fig_heatmap():
    table = load("ablation_table.json")
    n_pde, n_var = len(PDE_LIST), len(VARIANT_KEYS)
    data = np.array([[row[f"{k}_mean"] for k in VARIANT_KEYS]
                     for row in table], dtype=float)
    log_d = np.log10(np.clip(data, 1e-16, None))
    rmin  = log_d.min(axis=1, keepdims=True)
    rmax  = log_d.max(axis=1, keepdims=True)
    norm  = (log_d - rmin) / np.maximum(rmax - rmin, 1e-6)

    fig, ax = plt.subplots(figsize=(W2 * 0.72, 2.1))
    im = ax.imshow(norm, aspect="auto", cmap="RdYlGn_r",
                   vmin=0, vmax=1, interpolation="none")

    for i in range(n_pde):
        for j in range(n_var):
            br = norm[i, j]
            fc = "white" if br > 0.62 or br < 0.22 else "black"
            fw = "bold" if j >= 4 else "normal"
            ax.text(j, i, f"{data[i,j]:.1e}", ha="center", va="center",
                    fontsize=5.5, color=fc, fontweight=fw)

    ax.set_xticks(range(n_var))
    ax.set_xticklabels(VARIANT_LABELS, rotation=30, ha="right")
    ax.set_yticks(range(n_pde))
    ax.set_yticklabels(PDE_TITLES)
    ax.tick_params(length=0)

    # Box both Saddle methods (column indices 4 and 5)
    for j in [4, 5]:
        for i in range(n_pde):
            ax.add_patch(mpatches.Rectangle(
                (j-0.5, i-0.5), 1, 1, fill=False,
                edgecolor="black", linewidth=1.3, zorder=5))

    cbar = fig.colorbar(im, ax=ax, fraction=0.028, pad=0.02)
    cbar.set_label(r"Relative $\log_{10}|\bar{c}|$  (row-norm., green=best)", fontsize=7)
    cbar.ax.tick_params(labelsize=6)
    add_label(ax, "(a)", x=-0.10)
    ax.set_title(r"Mean conservation error $|\bar{c}|$ — row-normalised per PDE",
                 pad=4, fontsize=8)
    fig.tight_layout()
    savefig(fig, "fig2_ablation_heatmap")


# ─────────────────────────────────────────────────────────────────────────────
# FIGURE 3  Lagrange multiplier trajectories
# ─────────────────────────────────────────────────────────────────────────────
def fig_lambda():
    lam_data = load("lambda_history.json")
    AKEYS  = ["fixed", "sa", "saddle_grad", "saddle_adam"]
    ALBLS  = [r"Fixed-$\lambda$", "SA-PINN",
              r"Saddle-$\nabla$", r"Saddle-Adam$^\dagger$"]

    fig, axes = plt.subplots(2, 2, figsize=(W2, 4.0), sharex=True)
    axes = axes.flatten()

    for idx, (pde, title) in enumerate(zip(PDE_LIST, PDE_TITLES)):
        ax = axes[idx]
        for key, lbl in zip(AKEYS, ALBLS):
            item = next((d for d in lam_data if d["pde"]==pde and d["model"]==key), None)
            if not item: continue
            lam = smooth(np.array(item["lam_inv_history"]), 30)
            ax.plot(np.arange(len(lam)), lam, color=COLORS[key],
                    ls=LSTYLES[key], lw=LWIDTHS[key], label=lbl)

        ax.axvline(500, color="0.55", ls=":", lw=0.7)
        yhi = ax.get_ylim()[1]
        ax.text(520, yhi * 0.04, "warmup end", fontsize=5.5, color="0.5", va="bottom")
        ax.set_title(title, pad=3)
        ax.set_ylabel(r"$\lambda_{\rm inv}$")
        ax.tick_params(direction="in", length=2.5)
        add_label(ax, f"({'abcd'[idx]})")

    for ax in axes[2:]:
        ax.set_xlabel("Iteration")

    handles, labels = axes[0].get_legend_handles_labels()
    fig.legend(handles, labels, loc="lower center", ncol=4,
               bbox_to_anchor=(0.5, -0.03), frameon=True,
               handlelength=2.2, columnspacing=0.8)
    fig.suptitle(r"Evolution of the invariant multiplier $\lambda_{\rm inv}$",
                 y=1.01, fontsize=9)
    fig.tight_layout(rect=[0, 0.06, 1, 1])
    savefig(fig, "fig3_lambda_trajectories")


# ─────────────────────────────────────────────────────────────────────────────
# FIGURE 4  Loss convergence  3 rows × 4 cols
# ─────────────────────────────────────────────────────────────────────────────
def fig_loss_convergence():
    COMPS = [("Lp",   r"PDE residual $L_p$"),
             ("Lic",  r"IC loss $L_{ic}$"),
             ("Cinv", r"Constraint $\langle|\tilde{c}|\rangle$")]

    fig, axes = plt.subplots(3, 4, figsize=(W2, 5.5), sharex=True)
    pidx = 0

    for row, (comp, clbl) in enumerate(COMPS):
        for col, (pde, title) in enumerate(zip(PDE_LIST, PDE_TITLES)):
            ax = axes[row, col]
            for key in VARIANT_KEYS:
                fp = os.path.join(RESULT_DIR, f"{pde}_{key}_loss.json")
                if not os.path.exists(fp): continue
                with open(fp) as f:
                    loss = json.load(f)
                arr = np.abs(np.array(loss[comp], dtype=float))
                arr_s = smooth(arr, 60)
                if comp == "Cinv":
                    arr_s[:500] = np.nan
                ax.semilogy(arr_s, color=COLORS[key], ls=LSTYLES[key],
                            lw=LWIDTHS[key], alpha=0.92,
                            label=VARIANT_LABELS[VARIANT_KEYS.index(key)])

            if row == 0: ax.set_title(title, pad=3)
            if col == 0: ax.set_ylabel(clbl, labelpad=2)
            if row == 2: ax.set_xlabel("Iteration")
            ax.yaxis.set_major_formatter(
                ticker.LogFormatterSciNotation(labelOnlyBase=False))
            ax.tick_params(direction="in", length=2.0)
            add_label(ax, f"({'abcdefghijkl'[pidx]})", x=-0.24)
            pidx += 1

    handles, labels = axes[0, 0].get_legend_handles_labels()
    fig.legend(handles, labels, loc="lower center", ncol=len(VARIANT_KEYS),
               bbox_to_anchor=(0.5, -0.03), frameon=True,
               handlelength=2.2, columnspacing=0.6, fontsize=6)
    fig.tight_layout(rect=[0, 0.06, 1, 1])
    fig.subplots_adjust(hspace=0.28, wspace=0.40)
    savefig(fig, "fig4_loss_convergence")


# ─────────────────────────────────────────────────────────────────────────────
# FIGURE 5  Accuracy–time Pareto scatter
# ─────────────────────────────────────────────────────────────────────────────
def fig_pareto():
    table = load("ablation_table.json")
    fig, axes = plt.subplots(1, 4, figsize=(W2, 2.4))

    for idx, (pde, title) in enumerate(zip(PDE_LIST, PDE_TITLES)):
        ax = axes[idx]
        row = next(r for r in table if r["pde"] == pde)
        for key, lbl in zip(VARIANT_KEYS, VARIANT_LABELS):
            t = row[f"{key}_time"]
            c = row[f"{key}_mean"]
            ms = 8 if key in OUR_METHODS else 5
            ew = 1.3 if key in OUR_METHODS else 0.5
            ax.scatter(t, c, color=COLORS[key], marker=MARKERS[key],
                       s=ms**2, edgecolors="k", linewidths=ew,
                       zorder=5 if key in OUR_METHODS else 3, label=lbl)

        ax.set_yscale("log")
        ax.set_title(title, pad=3)
        ax.set_xlabel("Wall time (s)")
        if idx == 0:
            ax.set_ylabel(r"Mean $|\bar{c}|$")
        ax.tick_params(direction="in", length=2.5)
        add_label(ax, f"({'abcd'[idx]})", x=-0.22)

        best_k = min(VARIANT_KEYS, key=lambda k: row[f"{k}_mean"])
        note = "ours" if best_k in OUR_METHODS else "best"
        ax.annotate(note,
                    xy=(row[f"{best_k}_time"], row[f"{best_k}_mean"]),
                    xytext=(6, 6), textcoords="offset points",
                    fontsize=5, color=COLORS[best_k],
                    arrowprops=dict(arrowstyle="->", color=COLORS[best_k], lw=0.6))

    handles, labels = axes[0].get_legend_handles_labels()
    fig.legend(handles, labels, loc="lower center", ncol=len(VARIANT_KEYS),
               bbox_to_anchor=(0.5, -0.12), frameon=True,
               handlelength=1.2, handletextpad=0.3, columnspacing=0.6)
    fig.suptitle("Accuracy–cost Pareto frontier (lower-left = better)", y=1.02, fontsize=9)
    fig.tight_layout(rect=[0, 0.14, 1, 1])
    savefig(fig, "fig5_pareto_scatter")


# ─────────────────────────────────────────────────────────────────────────────
# FIGURE 6  Drift-rate bar chart
# ─────────────────────────────────────────────────────────────────────────────
def fig_drift():
    table = load("ablation_table.json")
    n_pde, n_var = len(PDE_LIST), len(VARIANT_KEYS)
    x, width = np.arange(n_pde), 0.12

    fig, ax = plt.subplots(figsize=(W2 * 0.68, 2.7))
    for i, (key, lbl) in enumerate(zip(VARIANT_KEYS, VARIANT_LABELS)):
        drifts = [row[f"{key}_drift"] for row in table]
        off    = (i - (n_var - 1) / 2) * width
        bars   = ax.bar(x + off, drifts, width * 0.90,
                        color=COLORS[key], label=lbl,
                        linewidth=0.4, edgecolor="k",
                        zorder=4 if key in OUR_METHODS else 2)
        if key in OUR_METHODS:
            for b in bars:
                b.set_hatch("//")

    ax.axhline(0, color="k", lw=0.8, zorder=5)
    ylim = ax.get_ylim()
    ax.axhspan(ylim[0], 0, color="0.94", zorder=0)
    ax.set_ylim(ylim)
    ax.text(n_pde - 0.1, ylim[0] * 0.82,
            r"$\leftarrow$ error decaying (better)", fontsize=5.5, color="0.4", ha="right")
    ax.set_xticks(x)
    ax.set_xticklabels(PDE_TITLES)
    ax.set_ylabel(r"Drift rate $\mathrm{d}|\tilde{c}|/\mathrm{d}t$")
    ax.tick_params(direction="in", length=2.5)
    ax.legend(loc="upper right", ncol=2, fontsize=6,
              framealpha=0.9, handlelength=1.6)
    add_label(ax, "(a)", x=-0.09)
    ax.set_title(r"Temporal drift of conservation error (hatched = proposed)", pad=4)
    fig.tight_layout()
    savefig(fig, "fig6_drift_rate")


