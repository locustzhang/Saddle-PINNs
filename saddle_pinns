# (E1) SADDLE‑PINN v3 – GRADIENT ASCENT
# ==============================================================================
class SaddlePINN_v3_Grad(BasePINN):
    label = "Saddle-v3 (Grad)"
    def __init__(self, out_dim, pde_type):
        super().__init__(out_dim, pde_type)
        self.lam_ic = float(LAMBDA_INIT)
        self.lam_inv = float(LAMBDA_INIT)
        self._was_warmup = True

    def compute_loss(self, x_f, t_f, x_ic, ts, residual_fn, ic_fn, inv_fn, inv0, warmup, tau):
        Lp,_ = causal_pde_loss(self, x_f, t_f, residual_fn, tau)
        Lic  = ic_loss(self, x_ic, ic_fn, self.out_dim)
        zero = torch.tensor(0.0, device=DEVICE)
        if warmup:
            Ltot = Lp + IC_WEIGHT_VANILLA * Lic
            return Ltot, dict(Lp=Lp, Lic=Lic, Cinv=zero, Linv=zero, Ltot=Ltot)
        if self.pde_type == "conservative":
            c_stack = constraint_conservative(self, ts, inv_fn, inv0)
        else:
            c_stack = constraint_burgers(self, ts, inv0)
        linv = torch.mean(self.lam_inv * c_stack + 0.5 * MU_PENALTY * c_stack ** 2)
        Ltot = Lp + self.lam_ic * Lic + 0.5 * MU_PENALTY * Lic**2 + linv
        return Ltot, dict(Lp=Lp, Lic=Lic, Cinv=c_stack.mean().detach(),
                          Linv=(c_stack**2).mean().detach(), Ltot=Ltot)

    def post_step(self, scalars):
        warmup = scalars["warmup"]
        if self._was_warmup and not warmup:
            self._was_warmup = False
        if not warmup:
            c_signal = float(scalars["Cinv"])
            self.lam_inv = float(np.clip(self.lam_inv + DUAL_LR_GRAD * c_signal, 0.0, LAMBDA_MAX))

# ==============================================================================
# (E2) SADDLE‑PINN v3 – ADAM ASCENT
# ==============================================================================
class SaddlePINN_v3_Adam(BasePINN):
    label = "Saddle-v3 (Adam)"
    def __init__(self, out_dim, pde_type):
        super().__init__(out_dim, pde_type)
        self.lam_ic = float(LAMBDA_INIT)
        self.lam_inv = float(LAMBDA_INIT)
        self.m_inv = 0.0
        self.v_inv = 0.0
        self.t_inv = 0
        self._was_warmup = True

    def _dual_adam_step(self, lam, c_signal, m, v, t, lam_max):
        t += 1
        m = DUAL_BETA1 * m + (1 - DUAL_BETA1) * c_signal
        v = DUAL_BETA2 * v + (1 - DUAL_BETA2) * (c_signal ** 2)
        m_hat = m / (1 - DUAL_BETA1 ** t)
        v_hat = v / (1 - DUAL_BETA2 ** t)
        step = DUAL_LR_ADAM * m_hat / (np.sqrt(v_hat) + DUAL_EPS)
        lam = float(np.clip(lam + step, 0.0, lam_max))
        return lam, m, v, t

    def reset_inv(self):
        self.m_inv = 0.0
        self.v_inv = 0.0
        self.t_inv = 0

    def compute_loss(self, x_f, t_f, x_ic, ts, residual_fn, ic_fn, inv_fn, inv0, warmup, tau):
        Lp,_ = causal_pde_loss(self, x_f, t_f, residual_fn, tau)
        Lic  = ic_loss(self, x_ic, ic_fn, self.out_dim)
        zero = torch.tensor(0.0, device=DEVICE)
        if warmup:
            Ltot = Lp + IC_WEIGHT_VANILLA * Lic
            return Ltot, dict(Lp=Lp, Lic=Lic, Cinv=zero, Linv=zero, Ltot=Ltot)
        if self.pde_type == "conservative":
            c_stack = constraint_conservative(self, ts, inv_fn, inv0)
        else:
            c_stack = constraint_burgers(self, ts, inv0)
        linv = torch.mean(self.lam_inv * c_stack + 0.5 * MU_PENALTY * c_stack ** 2)
        Ltot = Lp + self.lam_ic * Lic + 0.5 * MU_PENALTY * Lic**2 + linv
        return Ltot, dict(Lp=Lp, Lic=Lic, Cinv=c_stack.mean().detach(),
                          Linv=(c_stack**2).mean().detach(), Ltot=Ltot)

    def post_step(self, scalars):
        warmup = scalars["warmup"]
        if self._was_warmup and not warmup:
            self.reset_inv()
            self._was_warmup = False
        if not warmup:
            c_signal = float(scalars["Cinv"])
            self.lam_inv, self.m_inv, self.v_inv, self.t_inv = self._dual_adam_step(
                self.lam_inv, c_signal, self.m_inv, self.v_inv, self.t_inv, LAMBDA_MAX)

# ==============================================================================
# TRAINING LOOP (WITH CORRECTED SA‑PINN BACKWARD)
# ==============================================================================
def train_model(model, residual_fn, ic_fn, inv_fn, inv0, tau, desc=""):
    if isinstance(model, SAPINN):
        net_opt = torch.optim.Adam(model.net.parameters(), lr=LEARNING_RATE)
        dual_opt = torch.optim.Adam([model.log_lam_ic, model.log_lam_inv], lr=SA_LR)
        use_scheduler = False
    else:
        opt = torch.optim.Adam(model.parameters(), lr=LEARNING_RATE)
        use_scheduler = True

    if use_scheduler:
        scheduler = torch.optim.lr_scheduler.MultiStepLR(opt, LR_MILESTONES, LR_GAMMA)
    else:
        scheduler = None

    ts = time_slices(N_TS_INVARIANT)
    x_ic = sample_ic(N_IC_TRAIN)
    x_f, t_f = sample_colloc(N_TRAIN_COLLOC)

    rec = LossRecord()
    pbar = tqdm(range(1, ITERATIONS + 1), desc=desc, ncols=120, leave=False)

    for it in pbar:
        warmup = (it <= WARMUP_ITERS)

        if (RESAMPLE_INTERVAL > 0 and not warmup
                and (it - WARMUP_ITERS) % RESAMPLE_INTERVAL == 0):
            x_f, t_f = resample_collocation(model, x_f, t_f, residual_fn)

        model.train()

        if isinstance(model, SAPINN):
            # ---- SA-PINN: separate updates for network and λ ----
            loss_net, comps = model.compute_loss(
                x_f, t_f, x_ic, ts, residual_fn, ic_fn, inv_fn, inv0, warmup, tau)
            net_opt.zero_grad()
            loss_net.backward()
            nn.utils.clip_grad_norm_(model.net.parameters(), 1.0)
            net_opt.step()

            if not warmup:
                # Detach constraints so that dual backward doesn't interfere with network graph
                lic_val = comps["Lic"].detach()
                c_inv = comps["Cinv"].detach() if torch.is_tensor(comps["Cinv"]) else torch.tensor(comps["Cinv"])
                lam_ic = model.log_lam_ic.exp()
                lam_inv = model.log_lam_inv.exp()
                dual_loss = -(lam_ic * lic_val + lam_inv * c_inv)
                dual_opt.zero_grad()
                dual_loss.backward()
                dual_opt.step()
            else:
                dual_opt.zero_grad()
        else:
            # ---- Standard methods (A,B,C,E1,E2) ----
            opt.zero_grad()
            loss, comps = model.compute_loss(
                x_f, t_f, x_ic, ts, residual_fn, ic_fn, inv_fn, inv0, warmup, tau)
            loss.backward()
            nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            opt.step()
            if scheduler is not None:
                scheduler.step()

        scalars = {k: float(v.item()) if torch.is_tensor(v) else float(v)
                   for k, v in comps.items()}
        scalars["warmup"] = warmup
        model.post_step(scalars)

        rec.Lp.append(scalars["Lp"])
        rec.Lic.append(scalars["Lic"])
        rec.Cinv.append(scalars["Cinv"])
        rec.Linv.append(scalars["Linv"])
        rec.Ltot.append(scalars["Ltot"])
        rec.lam_ic.append(float(getattr(model, "lam_ic", 0.0)))
        rec.lam_inv.append(float(getattr(model, "lam_inv", 0.0)))

        if it % LOG_INTERVAL == 0:
            pbar.set_postfix(
                Lp=f"{scalars['Lp']:.1e}",
                Lic=f"{scalars['Lic']:.1e}",
                c=f"{scalars['Cinv']:.1e}",
                lam=f"{getattr(model,'lam_inv',0.0):.2f}",
                W="Y" if warmup else "N"
            )

    return rec

# ==============================================================================
# EVALUATION
# ==============================================================================
def eval_constraint_error(model, pde_type, inv_fn, inv0):
    model.eval()
    eps = 1e-12
    norm = abs(inv0) + eps
    errs = []
    with torch.enable_grad():
        for t in T_EVAL_LIST:
            x = quad_grid(N_INV_QUAD)
            if pde_type == "conservative":
                xt = torch.cat([x, float(t) * torch.ones_like(x)], dim=1)
                u = model(xt)
                I = inv_fn(u, x).item()
                c = abs((I - inv0) / norm)
            else:
                t_leaf = torch.tensor(float(t), device=DEVICE, requires_grad=True)
                xt = torch.cat([x, t_leaf.expand_as(x)], dim=1)
                u = model(xt)
                E = PDE.burgers_E(u, x)
                D = PDE.burgers_D(u, x)
                dEdt = autograd.grad(E, t_leaf, create_graph=False)[0].item()
                c = abs((dEdt + D.item()) / norm)
            errs.append(c)
    return {"mean": float(np.mean(errs)), "max": float(np.max(errs))}

def conservation_curve(model, pde_type, inv_fn, inv0):
    model.eval()
    eps = 1e-12
    norm = abs(inv0) + eps
    t_arr = np.linspace(0.0, T_FINAL, N_CONSERVATION_PTS)
    vals = []
    for t in t_arr:
        with torch.enable_grad():
            x = quad_grid(N_INV_QUAD)
            if pde_type == "conservative":
                xt = torch.cat([x, float(t) * torch.ones_like(x)], dim=1)
                u = model(xt)
                I = inv_fn(u, x).item()
                c = abs((I - inv0) / norm)
            else:
                t_leaf = torch.tensor(float(t), device=DEVICE, requires_grad=True)
                xt = torch.cat([x, t_leaf.expand_as(x)], dim=1)
                u = model(xt)
                E = PDE.burgers_E(u, x)
                D = PDE.burgers_D(u, x)
                dEdt = autograd.grad(E, t_leaf, create_graph=False)[0].item()
                c = abs((dEdt + D.item()) / norm)
            vals.append(float(c))
    drift = float(np.polyfit(t_arr, vals, 1)[0])
    return {"t": t_arr.tolist(), "c": vals,
            "mean": float(np.mean(vals)), "max": float(np.max(vals)),
            "drift_rate": drift}

# ==============================================================================
# EXPERIMENT RUNNER
# ==============================================================================
_VARIANT_KEYS   = ["vanilla", "penalty", "fixed", "sa", "saddle_grad", "saddle_adam"]
_VARIANT_LABELS = ["Vanilla", "Penalty", "Fixed-λ", "SA-PINN", "Saddle-Grad", "Saddle-Adam"]

def run_experiment(pde_name, out_dim, pde_type):
    log.info("=" * 70)
    log.info("PDE: %-10s | type=%-12s | out_dim=%d | tau=%.2f",
             pde_name, pde_type, out_dim, PDE_CAUSAL_TAU[pde_name])
    log.info("=" * 70)

    residual_fn, ic_fn, inv_fn = PDE_REGISTRY[pde_name]
    tau = PDE_CAUSAL_TAU[pde_name]

    x_ref = quad_grid(N_INV_QUAD)
    ic_val = ic_fn(x_ref)
    if out_dim == 2:
        ic_val = torch.cat([ic_val, torch.zeros_like(ic_val)], dim=1)

    if pde_type == "conservative":
        inv0 = float(inv_fn(ic_val, x_ref).item())
    else:
        inv0 = float(PDE.burgers_E(ic_val, x_ref).item())
    log.info("Reference I0/E0 = %.8f", inv0)

    variants = [
        ("vanilla", VanillaPINN(out_dim, pde_type)),
        ("penalty", PenaltyPINN(out_dim, pde_type)),
        ("fixed",   FixedLambdaPINN(out_dim, pde_type, pde_name)),
        ("sa",      SAPINN(out_dim, pde_type)),
        ("saddle_grad", SaddlePINN_v3_Grad(out_dim, pde_type)),
        ("saddle_adam", SaddlePINN_v3_Adam(out_dim, pde_type)),
    ]

    exp = {
        "pde": pde_name, "type": pde_type,
        "out_dim": out_dim, "inv0": inv0, "tau": tau,
        "models": {}
    }

    for key, model in variants:
        model.to(DEVICE)
        t0 = time.perf_counter()
        rec = train_model(model, residual_fn, ic_fn, inv_fn, inv0, tau,
                          desc=f"{pde_name}/{model.label}")
        wall = time.perf_counter() - t0

        err = eval_constraint_error(model, pde_type, inv_fn, inv0)
        curve = conservation_curve(model, pde_type, inv_fn, inv0)

        loss_dict = {k: v for k, v in dataclasses.asdict(rec).items()}
        with open(os.path.join(RESULT_DIR, f"{pde_name}_{key}_loss.json"), "w") as f:
            json.dump(loss_dict, f, indent=2)

        log.info("  [%-18s] mean|c|=%.3e  max|c|=%.3e  drift=%.3e  lam=%.3f  time=%.1fs",
                 model.label, err["mean"], err["max"], curve["drift_rate"],
                 float(getattr(model, "lam_inv", 0.0)), wall)

        exp["models"][key] = {
            "label": model.label,
            "wall_time_s": round(wall, 3),
            "error": err,
            "curve": curve,
            "final_loss": {
                "Lp": rec.Lp[-1], "Lic": rec.Lic[-1],
                "Cinv": rec.Cinv[-1], "Linv": rec.Linv[-1],
                "Ltot": rec.Ltot[-1]
            },
            "final_lambdas": {
                "lam_ic": float(getattr(model, "lam_ic", 0.0)),
                "lam_inv": float(getattr(model, "lam_inv", 0.0))
            },
            "loss_history": loss_dict
        }

    return exp

# ==============================================================================
# OUTPUT TABLES
# ==============================================================================
def build_ablation_table(all_results):
    rows = []
    for res in all_results:
        row = {"pde": res["pde"], "inv0": res["inv0"], "tau": res["tau"]}
        for k in _VARIANT_KEYS:
            m = res["models"][k]
            row[f"{k}_mean"]  = m["error"]["mean"]
            row[f"{k}_max"]   = m["error"]["max"]
            row[f"{k}_drift"] = m["curve"]["drift_rate"]
            row[f"{k}_time"]  = m["wall_time_s"]
            row[f"{k}_lam"]   = m["final_lambdas"]["lam_inv"]
        saddle_grad = max(row["saddle_grad_mean"], 1e-16)
        for k in _VARIANT_KEYS:
            row[f"ratio_{k}_saddle_grad"] = row[f"{k}_mean"] / saddle_grad
        rows.append(row)
    return rows

def build_conservation_table(all_results):
    rows = []
    for res in all_results:
        for k in _VARIANT_KEYS:
            m = res["models"][k]
            cc = m["curve"]
            rows.append({
                "pde": res["pde"],
                "model": k, "label": m["label"],
                "t": cc["t"], "c": cc["c"],
                "mean": cc["mean"], "max": cc["max"],
                "drift_rate": cc["drift_rate"]
            })
    return rows

def build_lambda_history(all_results):
    rows = []
    for res in all_results:
        for k in ("fixed", "sa", "saddle_grad", "saddle_adam"):
            if k in res["models"]:
                lh = res["models"][k]["loss_history"]["lam_inv"]
                rows.append({
                    "pde": res["pde"],
                    "model": k,
                    "label": res["models"][k]["label"],
                    "lam_inv_history": lh
                })
    return rows

# ==============================================================================
# MAIN
# ==============================================================================
def main():
    log.info("PyTorch %s | Device: %s", torch.__version__, DEVICE)
    log.info("ITER=%d  WARMUP=%d  MU=%.1f  SA_lr=%.3f  grad_lr=%.3f  adam_lr=%.3f",
             ITERATIONS, WARMUP_ITERS, MU_PENALTY, SA_LR, DUAL_LR_GRAD, DUAL_LR_ADAM)

    all_results = []
    for pde_name, out_dim, pde_type in PDE_LIST:
        all_results.append(run_experiment(pde_name, out_dim, pde_type))

    def _save(obj, fname):
        path = os.path.join(RESULT_DIR, fname)
        with open(path, "w") as f:
            json.dump(obj, f, indent=2)
        log.info("Saved → %s", path)

    _save(all_results,                           "results_summary.json")
    _save(build_ablation_table(all_results),     "ablation_table.json")
    _save(build_conservation_table(all_results), "conservation_curves.json")
    _save(build_lambda_history(all_results),     "lambda_history.json")

    abl = build_ablation_table(all_results)
    print("\nABLATION TABLE (mean |c|):")
    for r in abl:
        print(f"  {r['pde']:10s}  " +
              "  ".join(f"{r[f'{k}_mean']:.3e}" for k in _VARIANT_KEYS))

    log.info("✅ All experiments completed. Results in '%s/'", RESULT_DIR)

if __name__ == "__main__":
    main()
